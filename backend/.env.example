# Database — PostgreSQL connection string
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/testora

# JWT — generate a long random string, e.g. `openssl rand -hex 32`
SECRET_KEY=CHANGE_ME
ALGORITHM=HS256
# Token lifetime (minutes). 1440 = 24h. MUST exceed the longest task duration
# (a Writing task is allotted 40 min) so a token never expires mid-session.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated allowed browser origins. Localhost for dev; set real domains
# in production, e.g. "https://testora.studio,https://www.testora.studio".
CORS_ORIGINS=http://localhost:3000

# Day-boundary timezone for streaks / today's plan (IANA name).
APP_TIMEZONE=Asia/Almaty

# Input ceilings (defence against memory blowup, AI cost, and DoS).
MAX_AUDIO_UPLOAD_MB=15
MAX_WRITING_CHARS=20000

# AI grading provider: "mock" (free stubs), "claude", or "gemini"
AI_PROVIDER=mock

# Anthropic Claude — required when AI_PROVIDER=claude
ANTHROPIC_API_KEY=

# Google Gemini — required when AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
