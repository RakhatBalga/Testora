# Database — PostgreSQL connection string
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/testora

# JWT — generate a long random string, e.g. `openssl rand -hex 32`
SECRET_KEY=CHANGE_ME
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI grading provider: "mock" (free stubs), "claude", or "gemini"
AI_PROVIDER=mock

# Anthropic Claude — required when AI_PROVIDER=claude
ANTHROPIC_API_KEY=

# Google Gemini — required when AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
