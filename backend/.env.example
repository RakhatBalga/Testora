# Backend environment. Copy to `backend/.env` for local backend-only runs, or
# use the root `.env.example` with docker-compose.prod.yml for full production.

# Database — PostgreSQL connection string.
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/testora

# JWT — generate a long random string, e.g. `openssl rand -hex 32`
SECRET_KEY=CHANGE_ME
ALGORITHM=HS256
# Token lifetime (minutes). 1440 = 24h. MUST exceed the longest task duration
# (a Writing task is allotted 40 min) so a token never expires mid-session.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated allowed browser origins.
# Local dev: http://localhost:3000
# Production: https://app.testora.com,https://www.testora.com
CORS_ORIGINS=http://localhost:3000

# Day-boundary timezone for streaks / today's plan (IANA name).
APP_TIMEZONE=Asia/Almaty

# Input ceilings (defence against memory blowup, AI cost, and DoS).
MAX_AUDIO_UPLOAD_MB=15
MAX_WRITING_CHARS=20000

# AI grading provider: "mock" (local only), "claude", or "gemini".
# Production must use gemini with a real GEMINI_API_KEY; APP_ENV=production
# refuses to start with mock grading.
AI_PROVIDER=mock
APP_ENV=development

# Anthropic Claude — required when AI_PROVIDER=claude
ANTHROPIC_API_KEY=

# Google Gemini — required when AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
