# ---------------------------------------------------------------------------
# Testora — environment for docker-compose.prod.yml
# Copy to `.env` and fill in real values. NEVER commit the real .env.
# ---------------------------------------------------------------------------

# Postgres password for the bundled `db` service.
POSTGRES_PASSWORD=change-me-strong-random

# JWT signing secret. Generate with: openssl rand -hex 32
SECRET_KEY=change-me-openssl-rand-hex-32

# Access-token lifetime in minutes (default 1440 = 24h; must exceed the longest
# task duration so a token never expires mid-session).
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Production safety mode. The API refuses to start in production if grading
# would fall back to mock.
APP_ENV=production

# Comma-separated list of allowed browser origins = your production FRONTEND
# URL(s). Configurable without code changes — the backend reads CORS_ORIGINS at
# startup (settings.cors_origins_list). Local dev default: http://localhost:3000
CORS_ORIGINS=https://app.testora.com,https://www.testora.com

# Day-boundary timezone for streaks / today's plan (IANA name).
APP_TIMEZONE=Asia/Almaty

# Public base URL of the backend API (the production API URL), baked into the
# frontend at build time. The frontend reads it via NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_API_URL=https://api.testora.com

# AI grading for production.
AI_PROVIDER=gemini
GEMINI_API_KEY=change-me-real-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
